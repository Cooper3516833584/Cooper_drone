# ── MAVLink 串口 ──────────────────────────────
MAVLINK_PORT=/dev/ttyAMA0
MAVLINK_BAUD=115200

# ── RC 通道 ───────────────────────────────────
RC_MODE_CHANNEL=5
RC_KILL_CHANNEL=8

# ── 日志 ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── 视频推流 ──────────────────────────────────
STREAM_HOST=0.0.0.0
STREAM_PORT=5000
STREAM_FPS=15

# ── 摄像头 ────────────────────────────────────
CAMERA_INDEX=0
